rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PURE UTILITIES ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- ENTITY VALIDATIONS ---

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'date', 'amount', 'currency', 'type', 'personal_or_business', 'createdAt', 'updatedAt'])
        && data.keys().size() <= 15
        && data.userId == request.auth.uid
        && data.date is string
        && data.amount is number
        && data.currency in ['AED', 'INR']
        && data.type in ['income', 'expense', 'lent', 'borrowed']
        && data.personal_or_business in ['personal', 'business']
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidReminder(data) {
      return data.keys().hasAll(['userId', 'title', 'dueDate', 'status', 'createdAt', 'updatedAt'])
        && data.keys().size() <= 10
        && data.userId == request.auth.uid
        && data.title is string && data.title.size() <= 200
        && data.dueDate is string
        && data.status in ['pending', 'completed']
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidAccount(data) {
      return data.keys().hasAll(['userId', 'bankName', 'balance', 'currency', 'type', 'location', 'createdAt', 'updatedAt'])
        && data.keys().size() <= 10
        && data.userId == request.auth.uid
        && data.bankName is string && data.bankName.size() <= 100
        && data.balance is number
        && data.currency in ['AED', 'INR']
        && data.type in ['bank', 'cash', 'card']
        && data.location in ['UAE', 'India', 'Cash']
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    // --- COLLECTION RULES ---

    match /transactions/{transactionId} {
      allow get: if isOwner(existing().userId) && isValidId(transactionId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidId(transactionId) && isValidTransaction(incoming());
      
      allow update: if isOwner(existing().userId) 
        && isValidId(transactionId)
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'description', 'category', 'date', 'updatedAt'])
          && incoming().updatedAt == request.time
          && incoming().amount is number
          && incoming().date is string
        );
        
      allow delete: if isOwner(existing().userId);
    }

    match /reminders/{reminderId} {
      allow get: if isOwner(existing().userId) && isValidId(reminderId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidId(reminderId) && isValidReminder(incoming());
      
      allow update: if isOwner(existing().userId)
        && isValidId(reminderId)
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])
          && incoming().updatedAt == request.time
          && incoming().status in ['pending', 'completed']
        );
        
      allow delete: if isOwner(existing().userId);
    }

    match /accounts/{accountId} {
      allow get: if isOwner(existing().userId) && isValidId(accountId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidId(accountId) && isValidAccount(incoming());
      
      allow update: if isOwner(existing().userId)
        && isValidId(accountId)
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'bankName', 'location', 'updatedAt'])
          && incoming().updatedAt == request.time
          && incoming().balance is number
          && incoming().location in ['UAE', 'India', 'Cash']
        );
        
      allow delete: if isOwner(existing().userId);
    }
  }
}
